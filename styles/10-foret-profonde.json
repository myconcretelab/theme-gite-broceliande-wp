{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Foret profonde",
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#162016",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#F4F0E6",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#D6A84B",
					"name": "Accent 1",
					"slug": "accent-1"
				},
				{
					"color": "#D9C6A5",
					"name": "Accent 2",
					"slug": "accent-2"
				},
				{
					"color": "#7EA06D",
					"name": "Accent 3",
					"slug": "accent-3"
				},
				{
					"color": "#B8C4AE",
					"name": "Accent 4",
					"slug": "accent-4"
				},
				{
					"color": "#223022",
					"name": "Accent 5",
					"slug": "accent-5"
				},
				{
					"color": "#F4F0E633",
					"name": "Accent 6",
					"slug": "accent-6"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|manrope",
			"fontWeight": "300"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "999px"
				},
				"color": {
					"background": "var:preset|color|accent-1",
					"text": "var:preset|color|base"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|platypi",
					"fontWeight": "500"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|accent-1"
				}
			}
		}
	}
}
