{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Motif trame",
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"css": "body{background-image:linear-gradient(color-mix(in srgb,var(--wp--preset--color--contrast) 8%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,var(--wp--preset--color--contrast) 8%,transparent) 1px,transparent 1px);background-size:32px 32px}.wp-site-blocks{background:transparent}"
	}
}
